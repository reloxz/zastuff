	local function MakeDebrisParts(quantity, parent, position, size, orientation, cancollide, color, anchored, material, force)
		local parts = {}
		local actualquantity = 0
		repeat
			local part = Instance.new("Part")
			part.Parent = parent
			part.Transparency = 0
			part.CanCollide = cancollide
			part.CanTouch = false
			part.Position = position
			part.Size = size
			part.Material = material
			part.Anchored = anchored
			part.Orientation = orientation
			part.BrickColor = BrickColor.new(color)
			if part.BrickColor.Name == "Bright Red" then
				part.Name = "BloodPart"
			else
				part.Name = "DebrisPart"
			end
			part:ApplyImpulse(Vector3.new(math.random(-1, 1), math.random(-1, 1), math.random(-1, 1)) * force * part:GetMass())
			table.insert(parts, part)
			actualquantity += 1
		until actualquantity >= quantity
		return parts
	end

	local function EmitLight(color, rate)
		local emitter = this.Parent.Emitter
		if color == nil then
			emitter.Color = ColorSequence.new(this.Parent.Color)
		else
			emitter.Color = color
		end
		if rate == nil then
			emitter:Emit(emitter.Rate)
		else
			emitter:Emit(rate)
		end
	end

	local function Lightning()
		local hitparticles = this.Parent.HitParticles
		hitparticles.Color = ColorSequence.new(this.Parent.Color)
		hitparticles:Emit(hitparticles.Rate)
	end

